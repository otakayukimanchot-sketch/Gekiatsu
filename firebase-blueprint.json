{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "format": "uri", "description": "URL to user's profile picture" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created" }
      },
      "required": ["uid", "email"]
    },
    "QuizResult": {
      "title": "QuizResult",
      "description": "Result of a single quiz session",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who took the quiz" },
        "packId": { "type": "string", "description": "ID of the quiz pack" },
        "score": { "type": "integer", "description": "Number of correct answers" },
        "total": { "type": "integer", "description": "Total number of questions" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the quiz was completed" },
        "correctWords": { "type": "array", "items": { "type": "string" }, "description": "List of words answered correctly" },
        "incorrectWords": { "type": "array", "items": { "type": "string" }, "description": "List of words answered incorrectly" }
      },
      "required": ["userId", "packId", "score", "total", "timestamp"]
    },
    "UserProgress": {
      "title": "UserProgress",
      "description": "Overall progress of a user in a specific pack",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user" },
        "packId": { "type": "string", "description": "ID of the quiz pack" },
        "masteredWords": { "type": "array", "items": { "type": "string" }, "description": "List of words the user has mastered" },
        "lastPlayed": { "type": "string", "format": "date-time", "description": "Last time the user played this pack" }
      },
      "required": ["userId", "packId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/quizResults/{resultId}": {
      "schema": "QuizResult",
      "description": "Individual quiz attempt results"
    },
    "/userProgress/{progressId}": {
      "schema": "UserProgress",
      "description": "Aggregated user progress per pack"
    }
  }
}
